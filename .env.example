# ──────────────────────────────────────────────────────────────
# EvoDoc Clinical Drug Safety Engine — Environment Configuration
# ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# LLM Backend (Ollama local server)
# Recommended models (medical-specific, <2GB VRAM in 4-bit):
#   biomistral          — BioMistral-7B (best balance of medical accuracy + speed)
#   meditron            — Meditron-7B (OpenMed / EPFL)
#   openbiollm          — OpenBioLLM-8B
#   medllama3:8b        — MedLlama3 (if available in your Ollama registry)
OLLAMA_URL=http://localhost:11434
MODEL_NAME=biomistral

# Cache Configuration
# TTL in seconds (default: 3600 = 1 hour)
CACHE_TTL_SECONDS=3600

# Logging
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Application
# Port for uvicorn to bind on
APP_PORT=8000
APP_HOST=0.0.0.0
